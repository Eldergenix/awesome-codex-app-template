{
  "name": "enterprise-mono-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.12.0",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "quality": "python3 scripts/quality/agent_gate.py",
    "quality:secrets": "python3 scripts/quality/secret_scan.py",
    "quality:loc": "python3 scripts/quality/loc_guard.py",
    "quality:style": "python3 scripts/quality/style_guard.py",
    "quality:prompts": "python3 scripts/quality/prompt_file_guard.py",
    "ai:qc": "python3 scripts/ai-review/qc_review.py",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "eslint": "^9.20.0",
    "prettier": "^3.4.2",
    "turbo": "^2.9.14",
    "typescript": "^5.9.0",
    "@eslint/js": "^9.20.0"
  }
}
