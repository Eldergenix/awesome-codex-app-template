# Copy to .env.local. Values must come from your secret manager or platform config.

# Public Supabase client values
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Server-only Supabase values
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_JWKS_URL=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth/provider callback configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
EXPO_PUBLIC_AUTH_REDIRECT_SCHEME=enterpriseapp

# Telegram custom auth bridge
TELEGRAM_BOT_ID=
TELEGRAM_BOT_SECRET=

# AI provider keys. Do not expose to client bundles.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
AI_QC_PROVIDER=off
AI_QC_MODEL=gpt-5.5-pro

# MCP and integrations. Prefer OAuth where supported.
LINEAR_WORKSPACE_KEY=
NOTION_DOCS_DATABASE_ID=
NOTION_PACKAGES_DATABASE_ID=
NOTION_NOTES_DATABASE_ID=
NOTION_PROGRESS_DATABASE_ID=

# Setup wizard (dev-only API route guard — any non-empty string works locally)
SETUP_SECRET=

