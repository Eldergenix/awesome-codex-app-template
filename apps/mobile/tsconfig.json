{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@repo/theme": ["../../packages/theme/src/index.ts"],
      "@repo/supabase": ["../../packages/supabase/src/index.ts"],
      "@repo/validation": ["../../packages/validation/src/index.ts"]
    }
  },
  "include": ["app", "src", "nativewind-env.d.ts"]
}
